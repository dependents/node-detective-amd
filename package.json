{
  "name": "detective-amd",
  "version": "6.1.0",
  "description": "Find all dependencies within a JavaScript file using AMD module syntax",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "bin": {
    "detective-amd": "bin/cli.js"
  },
  "files": [
    "bin/cli.js",
    "index.js"
  ],
  "scripts": {
    "lint": "xo",
    "fix": "xo --fix",
    "uvu": "uvu test -i fixtures",
    "test": "npm run lint && npm run uvu",
    "test:ci": "c8 npm run uvu"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dependents/node-detective-amd.git"
  },
  "keywords": [
    "amd",
    "detective",
    "dependencies",
    "ast",
    "static analysis",
    "requirejs",
    "jsx",
    "module"
  ],
  "author": "Joel Kemp <joel@mrjoelkemp.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dependents/node-detective-amd/issues"
  },
  "homepage": "https://github.com/dependents/node-detective-amd",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "ast-module-types": "^6.0.1",
    "escodegen": "^2.1.0",
    "get-amd-module-type": "^6.0.2",
    "node-source-walk": "^7.0.1"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "uvu": "^0.5.6",
    "xo": "^2.0.2"
  }
}
